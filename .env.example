# Copy this file to .env and fill in real values. .env is gitignored — never commit real secrets.

# Your Groq API key, entered by the recruiter via the frontend at runtime in later phases —
# this env var is only used for local dev/testing before that UI exists.
GROQ_API_KEY=your-groq-api-key-here

# Postgres connection (used directly by psycopg2/SQLAlchemy, and to compose DATABASE_URL below)
POSTGRES_USER=resume_rag
POSTGRES_PASSWORD=changeme
POSTGRES_DB=resume_rag
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# SQLAlchemy connection string built from the Postgres values above
DATABASE_URL=postgresql://resume_rag:changeme@localhost:5432/resume_rag

# Redis, used as the RQ (background job queue) broker
REDIS_URL=redis://localhost:6379/0

# FastAPI/uvicorn bind address
API_HOST=0.0.0.0
API_PORT=8000
