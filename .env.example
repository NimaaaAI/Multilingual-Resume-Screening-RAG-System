# Copy this file to .env and fill in real values. .env is gitignored — never commit real secrets.

# LLM used for entity extraction (Phase 3) and candidate explanations (Phase 5).
# Uses the OpenAI-compatible chat completions API shape, so this works with an OpenAI-compatible
# proxy, Groq, or a local Ollama server (http://localhost:11434/v1) just by changing these values.
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://api.gapgpt.app/v1
LLM_MODEL=gpt-4o-mini

# Postgres connection (used directly by psycopg2/SQLAlchemy, and to compose DATABASE_URL below)
POSTGRES_USER=resume_rag
POSTGRES_PASSWORD=changeme
POSTGRES_DB=resume_rag
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# SQLAlchemy connection string built from the Postgres values above
DATABASE_URL=postgresql://resume_rag:changeme@localhost:5432/resume_rag

# Separate database used only by the test suite, so tests never touch dev data.
# Create it locally with: createdb resume_rag_test --owner=resume_rag
TEST_DATABASE_URL=postgresql://resume_rag:changeme@localhost:5432/resume_rag_test

# Redis, used as the RQ (background job queue) broker
REDIS_URL=redis://localhost:6379/0

# FastAPI/uvicorn bind address
API_HOST=0.0.0.0
API_PORT=8000
